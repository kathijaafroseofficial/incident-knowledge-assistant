# Copy to .env and fill in values.
# For free public deployment (Streamlit Cloud / Hugging Face), set these as Secrets; see DEPLOYMENT.md.

# Bearer token for public POST endpoint (generate a secure random string in production)
API_BEARER_TOKEN=your_secure_bearer_token_here

# --- Production: use one of the 3 bots (MoltBot / ClawDBot / Nanobot) ---
# Set BOT_PROVIDER to the bot you use, or "auto" to use the first URL that is set below.
# At least one of MOLTBOT_URL, CLAWDBOT_URL, NANOBOT_URL must be set (no Ollama default).
BOT_PROVIDER=auto
# Giggso / your gateway base URLs (in production inject via env, e.g. Kubernetes Secret)
MOLTBOT_URL=
CLAWDBOT_URL=
NANOBOT_URL=

# Multi-bot: set true to call all configured 3-bot URLs and show each reply
MULTI_BOT_ENABLED=false
# Set true to also include Ollama/OpenClaw/OpenAI in multi-bot (default: only the 3 bots above)
INCLUDE_FALLBACK_BOTS_IN_MULTI=false

# --- Optional: OpenClaw, Ollama, OpenAI-compatible (only if BOT_PROVIDER is set to one) ---
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_AUTH_TOKEN=
OPENCLAW_AGENT_ID=main
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_COMPATIBLE_URL=
OPENAI_COMPATIBLE_API_KEY=
